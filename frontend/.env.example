# Exposure Eclipse — frontend environment template.
# Copy to frontend/.env. Vite requires the VITE_ prefix for runtime access.
# Spec: docs/STACK_AND_SETUP.md

# API root. In dev, Vite proxies /api → http://localhost:8000 (vite.config.ts).
VITE_API_BASE_URL=/api

# Mapbox GL JS token. NEVER hardcode (CLAUDE.md rule 8). [OPEN: provisioning]
VITE_MAPBOX_TOKEN=
