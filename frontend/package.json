{
  "name": "exposure-eclipse-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Exposure Eclipse — Property Cat exposure management workbench (React + Vite frontend).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
