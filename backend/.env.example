# Exposure Eclipse — backend environment template.
# Copy to backend/.env and fill in real values. Do NOT commit secrets.
# Spec: docs/STACK_AND_SETUP.md

# Data provider: mock | sqlserver | databricks
DATA_PROVIDER=mock

# Mock provider fixture location (relative to backend/ or absolute)
MOCK_DATA_DIR=../mockdata

# Error report recipient — config only, never hardcoded (CLAUDE.md rule 8)
SUPPORT_ERROR_EMAIL=support@example.invalid

# Email transport: smtp | graph | noop
EMAIL_TRANSPORT=noop
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Excel export ceiling (triggers WARN_EXPORT_TOO_LARGE / EXPORT_TOO_LARGE)
EXPORT_MAX_ROWS=100000

# CORS — comma-separated list of allowed dev origins
# 5173 = npm run dev (proxied), 4173 = npm run preview (direct calls, needs CORS)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# v1 phase 2 only
# SQLSERVER_CONN=

# v2 only
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
# DATABRICKS_WAREHOUSE_ID=
